# CaratIQ — environment template. Copy to .env.local and fill in real values.
# Full instructions: ENV_SETUP.md

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Random 32+ char secrets (openssl rand -base64 32)
SESSION_SECRET=
VAULT_SECRET=

# Admin portal login (rootdomain/admin)
ADMIN_EMAIL=admin@caratiq.com
ADMIN_PASSWORD=caratiq-admin
# ADMIN_PASSWORD_HASH=

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=8801700000000
NEXT_PUBLIC_CONTACT_EMAIL=hello@caratiq.com

# AI analyzer — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANALYZE_DAILY_LIMIT=15

# Google Analytics + Search Console (admin dashboard real-time data) — optional
# Enable "Google Analytics Data API" + "Google Search Console API" in Google Cloud,
# create a service account, grant it access to your GA4 property + Search Console.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GA4_PROPERTY_ID=
GSC_SITE_URL=https://diamondstester.com
